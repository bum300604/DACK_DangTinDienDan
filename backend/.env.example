# Gửi OTP quên mật khẩu — bắt buộc SMTP_HOST + SMTP_USER + SMTP_PASS (trừ khi bật chế độ dev bên dưới)
# Gmail: SMTP_HOST=smtp.gmail.com, bật xác minh 2 bước và dùng "Mật khẩu ứng dụng" (không phải mật khẩu đăng nhập)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
MAIL_FROM=your-email@gmail.com
# Chỉ môi trường dev: không có SMTP_HOST nhưng vẫn muốn test OTP — in mã ra console server
# SMTP_CONSOLE_OTP=true
